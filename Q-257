class Solution {
    public List<String> binaryTreePaths(TreeNode root) {
        List<String> res = new ArrayList<>();
        if (root == null) return res;  
        StringBuilder sb = new StringBuilder();
        buildPaths(root, sb, res);
        return res;
    }

    private void buildPaths(TreeNode node, StringBuilder sb, List<String> res) {
        if (node == null) return;
        int lengthBeforeAppend = sb.length();
        sb.append(node.val);
        if (node.left == null && node.right == null) {
            res.add(sb.toString());
        } else {
            sb.append("->");
            buildPaths(node.left, sb, res);
            buildPaths(node.right, sb, res);
        }
        sb.setLength(lengthBeforeAppend);
    }
}
